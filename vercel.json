{
  "version": 2,
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "snack-voice.vercel.app"
        }
      ],
      "destination": "https://snackvoice.snackoverflowgeorge.com",
      "permanent": true
    },
    {
      "source": "/desktop-auth.html",
      "has": [
        {
          "type": "host",
          "value": "snack-voice.vercel.app"
        }
      ],
      "destination": "https://snackvoice.snackoverflowgeorge.com/desktop-auth.html",
      "permanent": true
    },
    {
      "source": "/privacy.html",
      "has": [
        {
          "type": "host",
          "value": "snack-voice.vercel.app"
        }
      ],
      "destination": "https://snackvoice.snackoverflowgeorge.com/privacy.html",
      "permanent": true
    },
    {
      "source": "/terms.html",
      "has": [
        {
          "type": "host",
          "value": "snack-voice.vercel.app"
        }
      ],
      "destination": "https://snackvoice.snackoverflowgeorge.com/terms.html",
      "permanent": true
    },
    {
      "source": "/success.html",
      "has": [
        {
          "type": "host",
          "value": "snack-voice.vercel.app"
        }
      ],
      "destination": "https://snackvoice.snackoverflowgeorge.com/success.html",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    }
  ],
  "functions": {
    "api/index.js": {
      "runtime": "@vercel/node@5.3.24"
    }
  }
}
