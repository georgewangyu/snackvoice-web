# SnackVoice Web — Environment Variables
# Copy this to backend/.env and fill in your values

# Server
PORT=4200
APP_URL=http://localhost:4200

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...          # One-time price you created in Stripe

# Mac app download links (optional direct URLs if you are not using S3)
DOWNLOAD_URL_ARM64=https://github.com/yourorg/snackvoice/releases/latest/download/SnackVoice-Apple-Silicon.dmg
DOWNLOAD_URL_X64=https://github.com/yourorg/snackvoice/releases/latest/download/SnackVoice-Intel.dmg

# Optional private S3 delivery
S3_BUCKET=
S3_KEY_ARM64=SnackVoice-Apple-Silicon.dmg
S3_KEY_X64=SnackVoice-Intel.dmg
AWS_REGION=us-west-2
S3_SIGNED_URL_TTL_SECONDS=86400
