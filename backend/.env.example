# SnackVoice Web — Environment Variables
# Copy this to backend/.env and fill in your values

# Server
PORT=4200
APP_URL=http://localhost:4200
# Optional: override data-file locations (useful for isolated tests)
# ORDERS_DATA_PATH=backend/data/orders.json
# BILLING_DATA_PATH=backend/data/billing.json
# Optional: use Supabase/Postgres storage instead of local JSON files
# SUPABASE_DB_URL=postgresql://postgres:<password>@<host>:5432/postgres
# DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres
# SUPABASE_DB_SSL=true
# SUPABASE_DB_POOL_MAX=8
# Supabase Auth (recommended for production account login)
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_ANON_KEY=ey...
# Keep false in production to avoid a second auth request per signup.
SUPABASE_SIGNUP_AUTO_SIGNIN=false

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...   # $14.99 monthly recurring price
STRIPE_PRICE_ID_ANNUAL=price_...    # $149.99 annual recurring price
STRIPE_DEFAULT_PLAN=monthly         # monthly or annual
# Legacy fallback if monthly var is missing
STRIPE_PRICE_ID=price_...
FREE_WEEKLY_WORD_QUOTA=1000
WEEKLY_RESET_DAY_UTC=1              # 0=Sun, 1=Mon
OUTAGE_GRACE_HOURS=12

# Auth/session
SNACKVOICE_AUTH_SECRET=replace_me
SESSION_TTL_DAYS=30
MIN_PASSWORD_LENGTH=8
ALLOW_DEV_EMAIL_AUTH=true

# Mac app download links (optional direct URLs if you are not using S3)
DOWNLOAD_URL_ARM64=https://github.com/yourorg/snackvoice/releases/latest/download/SnackVoice-Apple-Silicon.dmg
DOWNLOAD_URL_X64=https://github.com/yourorg/snackvoice/releases/latest/download/SnackVoice-Intel.dmg

# Optional private S3 delivery
S3_BUCKET=
S3_KEY_ARM64=SnackVoice-Apple-Silicon.dmg
S3_KEY_X64=SnackVoice-Intel.dmg
AWS_REGION=us-west-2
S3_SIGNED_URL_TTL_SECONDS=86400
