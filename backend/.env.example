# SnackVoice Web — Environment Variables
# Copy this to backend/.env and fill in your values

# Server
PORT=4200
APP_URL=http://localhost:4200

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...          # One-time price you created in Stripe

# Keygen (https://app.keygen.sh)
KEYGEN_ACCOUNT_ID=...
KEYGEN_ACCOUNT_TOKEN=...           # Admin token
KEYGEN_POLICY_ID=...               # Policy for SnackVoice licenses

# Mac app download link (GitHub release .dmg URL)
DOWNLOAD_URL=https://github.com/yourorg/snackvoice/releases/latest/download/SnackVoice.dmg

# SMTP (for sending delivery emails)
# You can use Resend, Postmark, Gmail SMTP, etc.
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_...
FROM_EMAIL=noreply@snackvoice.app
